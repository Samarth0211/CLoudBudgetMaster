# ==================================
# CloudPilot Backend - Environment Variables
# ==================================
# Copy this file to backend/.env and fill in your values
# cp .env.example backend/.env

# ── Database: self-hosted PostgreSQL (Required) ──
DATABASE_URL=postgresql://cbm:your-db-password@127.0.0.1:5432/cloudbudgetmaster

# ── Auth (Required) ──
# Secret for signing JWTs — any long random string (e.g. `openssl rand -hex 32`).
# Falls back to CREDENTIAL_ENCRYPTION_KEY if unset.
JWT_SECRET=generate-a-long-random-string

# ── Security (Required) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=your-generated-fernet-key-here

# ── Groq AI (Required for AI features) ──
# Get free key from: https://console.groq.com → API Keys
# Free tier: 30 requests/minute, 14,400 requests/day
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Email: Hostinger SMTP only (no Resend/SendGrid) ──
# Configured below in the SMTP block. Transactional email sends from
# support@cloudbudgetmaster.com via smtp.hostinger.com.

# ── Anthropic (Optional - reserved for future RAG) ──
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── PayPal Payments (Required for paid plans) ──
# Create an app at https://developer.paypal.com → Apps & Credentials.
# Use the LIVE app's credentials for real money; keep paypal_mode=live.
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox            # 'sandbox' for testing, 'live' for real charges

# ── SMTP (Required for verification + reset emails; also contact notifications) ──
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=you@cloudbudgetmaster.com
SMTP_PASSWORD=your_mailbox_password
SMTP_FROM_EMAIL=you@cloudbudgetmaster.com
# Where contact-form submissions are emailed (defaults to SMTP_USER if unset)
# CONTACT_NOTIFY_EMAIL=you@cloudbudgetmaster.com

# ── App Config ──
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
