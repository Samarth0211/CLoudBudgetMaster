# ==================================
# CloudPilot Backend - Environment Variables
# ==================================
# Copy this file to backend/.env and fill in your values
# cp .env.example backend/.env

# ── Supabase (Required) ──
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...your-service-role-key

# ── Security (Required) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=your-generated-fernet-key-here

# ── Groq AI (Required for AI features) ──
# Get free key from: https://console.groq.com → API Keys
# Free tier: 30 requests/minute, 14,400 requests/day
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Resend Email (Optional - for email alerts) ──
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here

# ── Anthropic (Optional - reserved for future RAG) ──
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Razorpay Payments (Optional - not yet active) ──
# RAZORPAY_KEY_ID=rzp_test_your_key_here
# RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── App Config ──
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
